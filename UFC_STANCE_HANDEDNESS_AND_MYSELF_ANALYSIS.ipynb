    last_names = ['Jones', 'McGregor', 'Nurmagomedov', 'Silva', 'St-Pierre',
                  'Cormier', 'Nunes', 'Rousey', 'Adesanya', 'Ngannou',
                  'Poirier', 'Holloway', 'Ferguson', 'Diaz', 'Usman',
                  'Volkanovski', 'Yan', 'Sterling', 'Namajunas', 'Weili',
                  'Shevchenko', 'Oliveira']
                  # Thêm vào phần khai báo first_names, last_names (sau dòng đó)

    # List of countries with realistic MMA representation
    countries = [
        'USA', 'Brazil', 'Russia', 'Canada', 'United Kingdom',
        'Australia', 'France', 'Germany', 'Japan', 'South Korea',
        'China', 'Mexico', 'Poland', 'Netherlands', 'Sweden',
        'Nigeria', 'Ireland', 'New Zealand', 'Vietnam', 'Thailand',
        'Philippines', 'Italy', 'Spain', 'Argentina', 'Norway'
    ]

    # Country probabilities (more fighters from USA, Brazil, Russia)
    country_weights = [
        0.265,  # USA (adjusted from 0.25 to make sum of probabilities 1)
        0.15,  # Brazil
        0.10,  # Russia
        0.07,  # Canada
        0.07,  # UK
        0.05,  # Australia
        0.04,  # France
        0.04,  # Germany
        0.03,  # Japan
        0.03,  # South Korea
        0.02,  # China
        0.02,  # Mexico
        0.02,  # Poland
        0.02,  # Netherlands
        0.01,  # Sweden
        0.01,  # Nigeria
        0.01,  # Ireland
        0.01,  # New Zealand
        0.005, # Vietnam
        0.005, # Thailand
        0.005, # Philippines
        0.005, # Italy
        0.005, # Spain
        0.005, # Argentina
        0.005  # Norway
    ]
    # Generate countries for fighters
    fighter_countries = np.random.choice(countries, n_fighters, p=country_weights)
    fighter_names = [f"{np.random.choice(first_names)} {np.random.choice(last_names)}"
                     for _ in range(n_fighters)]

    # Generate stance data (realistic distribution)
    stances = np.random.choice(['Orthodox', 'Southpaw', 'Switch'],
                                n_fighters, p=[0.65, 0.30, 0.05])

    # Generate win/loss data with realistic correlations
    base_wins = np.random.poisson(12, n_fighters)
    base_losses = np.random.poisson(5, n_fighters)
    base_draws = np.random.poisson(0.3, n_fighters)

    # Adjust for stance advantage
    wins = np.where(np.array(stances) == 'Southpaw',
                    base_wins + np.random.poisson(2, n_fighters),
                    base_wins)

    # Create DataFrame
    df = pd.DataFrame({
        'fighter_name': fighter_names,
        'country': fighter_countries,  # <-- THÊM DÒNG NÀY
        'fighter_stance': stances,
        'fighter_wins': wins,
        'fighter_losses': base_losses,
        'fighter_draws': base_draws
    })

    # Clean and preprocess the synthetic data immediately
    df_clean = df[['fighter_name', 'country', 'fighter_stance',
                   'fighter_wins', 'fighter_losses', 'fighter_draws']].copy()

    for col in ['fighter_wins', 'fighter_losses', 'fighter_draws']:
        df_clean[col] = pd.to_numeric(df_clean[col], errors='coerce')

    df_clean = df_clean.dropna(subset=['fighter_wins', 'fighter_losses', 'fighter_draws'])

    df_clean['total_fights'] = (
    df_clean['fighter_wins'] +
                                df_clean['fighter_losses'] +
                                df_clean['fighter_draws'])

    df_clean['win_rate'] = np.where(
        df_clean['total_fights'] > 0,
        (df_clean['fighter_wins'] / df_clean['total_fights'] * 100).round(2),
        0
    )

    df_clean = df_clean[df_clean['total_fights'] >= 5]
    df_clean = df_clean[df_clean['fighter_stance'].isin(['Orthodox', 'Southpaw'])]


    # ======================================================================
# COUNTRY ANALYSIS
# ======================================================================
    print("\n" + "="*70)
    print("🌍 COUNTRY ANALYSIS")
    print("="*70)

    # Top countries by fighter count
    country_counts = df_clean['country'].value_counts().head(10)
    print("\n🏆 TOP 10 COUNTRIES BY FIGHTER COUNT:")
    for country, count in country_counts.items():
        print(f"   • {country}: {count} fighters")

    # Best countries by win rate (minimum 10 fighters)
    country_win_rates = df_clean.groupby('country').agg({
        'win_rate': ['mean', 'count']
    }).round(2)
    country_win_rates.columns = ['mean_win_rate', 'fighter_count']
    top_countries = country_win_rates[country_win_rates['fighter_count'] >= 10].sort_values('mean_win_rate', ascending=False).head(10)
    print("\n🏆 TOP 10 COUNTRIES BY WIN RATE (min 10 fighters):")
    for idx, row in top_countries.iterrows():
        print(f"   • {idx}: {row['mean_win_rate']:.1f}% ({row['fighter_count']} fighters)")
        # Export to CSV for Tableau (có thêm country)
    df_clean.to_csv('ufc_fighters_tableau.csv', index=False)
    print("\n✅ Exported ufc_fighters_tableau.csv with country data")

    # Add some elite fighters (champions)
    elite_indices = np.random.choice(n_fighters, 50, replace=False)
    df.loc[elite_indices, 'fighter_wins'] += np.random.poisson(10, 50)

    print(f"\n✅ Generated {n_fighters} synthetic fighters")
    print(f"   Orthodox: {(df['fighter_stance'] == 'Orthodox').sum()} fighters")
    print(f"   Southpaw: {(df['fighter_stance'] == 'Southpaw').sum()} fighters")
    print(f"   Switch: {(df['fighter_stance'] == 'Switch').sum()} fighters")

except Exception as e:
