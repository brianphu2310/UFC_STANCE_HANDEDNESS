# 3.  BUILD DATAFRAME
# ══════════════════════════════════════════════════════════════════════════════

def build_dataframe(raw):
    cols = ["fighter_name","country","continent","fighter_stance",
            "hand_dominance","wins","losses"]
    df = pd.DataFrame(raw, columns=cols)
    df["wins"]   = pd.to_numeric(df["wins"],   errors="coerce")
    df["losses"] = pd.to_numeric(df["losses"], errors="coerce")
    df = df.dropna(subset=["wins","losses"])
    df["total_fights"] = df["wins"] + df["losses"]
    df["win_rate"]     = (df["wins"] / df["total_fights"] * 100).round(2)
    df["stance_hand"]  = df["fighter_stance"] + " + " + df["hand_dominance"] + "-handed"
    df = df[df["fighter_stance"].isin(["Orthodox","Southpaw"])]
    df = df[df["total_fights"] >= 5]
    df = df.drop_duplicates(subset="fighter_name", keep="first").reset_index(drop=True)
    return df

df = build_dataframe(RAW)

# Groups
orth_all   = df[df["fighter_stance"] == "Orthodox"]
south_all  = df[df["fighter_stance"] == "Southpaw"]
orth_right = df[(df["fighter_stance"]=="Orthodox")  & (df["hand_dominance"]=="Right")]
orth_left  = df[(df["fighter_stance"]=="Orthodox")  & (df["hand_dominance"]=="Left")]
south_left = df[(df["fighter_stance"]=="Southpaw")  & (df["hand_dominance"]=="Left")]
south_right= df[(df["fighter_stance"]=="Southpaw")  & (df["hand_dominance"]=="Right")]

MY_GROUP = south_right
GROUPS   = {
    "Orthodox + Right-handed": orth_right,
    "Orthodox + Left-handed":  orth_left,
    "Southpaw + Left-handed":  south_left,
    "Southpaw + Right-handed": south_right,
}
others = df[~df.index.isin(MY_GROUP.index)]


# ══════════════════════════════════════════════════════════════════════════════
# 4.  STATISTICS
# ══════════════════════════════════════════════════════════════════════════════

def grp_stats(g, name):
    wr = g["win_rate"]
    return {"group":name,"n":len(g),"pct":len(g)/len(df)*100,
            "mean":round(wr.mean(),2),"median":round(wr.median(),2),
            "std":round(wr.std(),2),"q1":round(wr.quantile(.25),2),
            "q3":round(wr.quantile(.75),2),"min":round(wr.min(),2),"max":round(wr.max(),2)}

stats_df      = pd.DataFrame([grp_stats(g,n) for n,g in GROUPS.items()])
my_s          = stats_df[stats_df["group"]=="Southpaw + Right-handed"].iloc[0]
orth_right_s  = stats_df[stats_df["group"]=="Orthodox + Right-handed"].iloc[0]
south_left_s  = stats_df[stats_df["group"]=="Southpaw + Left-handed"].iloc[0]
others_mean   = others["win_rate"].mean()

t_stance, p_stance = stats.ttest_ind(orth_all["win_rate"], south_all["win_rate"])
t_me,     p_me     = stats.ttest_ind(MY_GROUP["win_rate"], others["win_rate"], equal_var=False)

print("="*65)
print(f"  Dataset : {len(df)} fighters | {df['country'].nunique()} countries")
print(f"  Orthodox: {len(orth_all)}  | Southpaw: {len(south_all)}")
print(f"  Stance p-value : {p_stance:.4f}  {'SIG' if p_stance<.05 else 'n.s.'}")
print(f"  My group p-val : {p_me:.4f}  {'SIG' if p_me<.05 else 'n.s.'}")
print("="*65)


