style_ax(ax_a4, "FIGHTER FREQUENCY", xlabel="Win Rate (%)", ylabel="# Fighters")
bins = np.linspace(0, 100, 18)
ax_a4.hist(orth_all["win_rate"],  bins=bins, alpha=0.75, label="Orthodox",
           color=UFC_RED,  edgecolor=UFC_BLACK, linewidth=0.6)
ax_a4.hist(south_all["win_rate"], bins=bins, alpha=0.75, label="Southpaw",
           color=UFC_GOLD, edgecolor=UFC_BLACK, linewidth=0.6)
ax_a4.axvline(50, color=UFC_WHITE, lw=1.2, ls="--", alpha=0.5)
ax_a4.legend(fontsize=8, loc="upper left")


# ══════════════════════════════════════════════════════════════════════════════
# ROW B — Country & Continent Analysis
# ══════════════════════════════════════════════════════════════════════════════

# B1 — Continent donut
ax_b1 = fig.add_subplot(gs[2, 0])
style_ax(ax_b1, "FIGHTERS BY CONTINENT")
cont_counts = df["continent"].value_counts()
cont_colors = [CONTINENT_COLORS.get(c, "#888") for c in cont_counts.index]
wedges, _, autotexts = ax_b1.pie(
    cont_counts.values, autopct="%1.0f%%", colors=cont_colors,
    startangle=90,
    wedgeprops=dict(width=0.55, edgecolor=UFC_BLACK, linewidth=1.5),
    textprops=dict(color=UFC_WHITE, fontsize=7.5))
for at in autotexts: at.set_fontweight("bold")
ax_b1.set_aspect("equal")
patches = [mpatches.Patch(color=CONTINENT_COLORS.get(c,"#888"),
           label=f"{c} ({v})") for c,v in cont_counts.items()]
ax_b1.legend(handles=patches, loc="lower center",
             bbox_to_anchor=(0.5, -0.20), ncol=2,
             fontsize=7, framealpha=0.08, labelcolor=UFC_WHITE)

# B2 — Top countries horizontal bar
ax_b2 = fig.add_subplot(gs[2, 1])
style_ax(ax_b2, "TOP 12 COUNTRIES", xlabel="# Fighters")
top12 = df["country"].value_counts().head(12)
cont_map = df.drop_duplicates("country").set_index("country")["continent"]
bar_colors = [CONTINENT_COLORS.get(cont_map.get(c,""), UFC_GREY) for c in top12.index]
yp = np.arange(len(top12))
hbars = ax_b2.barh(yp, top12.values, color=bar_colors, alpha=0.85,
                   edgecolor=UFC_BLACK, linewidth=0.5)
ax_b2.set_yticks(yp)
ax_b2.set_yticklabels(top12.index, color=UFC_WHITE, fontsize=8)
ax_b2.invert_yaxis()
for bar, val in zip(hbars, top12.values):
    ax_b2.text(bar.get_width()+0.1, bar.get_y()+bar.get_height()/2,
               str(val), va="center", color=UFC_WHITE, fontsize=8)

# B3 — Scatter: country fighter count vs avg win rate
ax_b3 = fig.add_subplot(gs[2, 2])
style_ax(ax_b3, "COUNTRY: SIZE vs AVG WIN RATE",
         xlabel="# Fighters", ylabel="Avg Win Rate (%)")
cagg = (df.groupby(["country","continent"])
        .agg(n=("fighter_name","count"), avg_wr=("win_rate","mean"))
        .reset_index())
for cont, grp in cagg.groupby("continent"):
    ax_b3.scatter(grp["n"], grp["avg_wr"],
                  color=CONTINENT_COLORS.get(cont,"#888"),
                  s=grp["n"]*9+25, alpha=0.75,
                  edgecolors=UFC_WHITE, linewidths=0.4,
                  label=cont, zorder=3)
for _, row in cagg[cagg["country"].isin(
        ["USA","Brazil","Russia","Ireland","Nigeria","Australia","Japan","France"])].iterrows():
    ax_b3.annotate(row["country"], (row["n"], row["avg_wr"]),
                   xytext=(5,3), textcoords="offset points",
                   color=UFC_WHITE, fontsize=7, alpha=0.85)
ax_b3.axhline(50, color=UFC_RED, lw=1, ls="--", alpha=0.5)
ax_b3.legend(fontsize=7, markerscale=0.65, loc="lower right")

# B4 — Stacked bar: stance per continent
ax_b4 = fig.add_subplot(gs[2, 3])
style_ax(ax_b4, "STANCE SPLIT BY CONTINENT")
sc = (df.groupby(["continent","fighter_stance"]).size().unstack(fill_value=0))
sc = sc.reindex(sorted(sc.index, key=lambda c: sc.loc[c].sum(), reverse=True))
xc = np.arange(len(sc))
ov = sc.get("Orthodox", pd.Series(0, index=sc.index)).values
sv = sc.get("Southpaw", pd.Series(0, index=sc.index)).values
ax_b4.bar(xc, ov, color=UFC_RED,  alpha=0.85, label="Orthodox",
          edgecolor=UFC_BLACK, linewidth=0.5)
ax_b4.bar(xc, sv, bottom=ov, color=UFC_GOLD, alpha=0.85, label="Southpaw",
          edgecolor=UFC_BLACK, linewidth=0.5)
ax_b4.set_xticks(xc)
ax_b4.set_xticklabels(sc.index, rotation=28, ha="right", color=UFC_WHITE, fontsize=7.5)
ax_b4.set_ylabel("# Fighters", color=UFC_SILVER, fontsize=8.5)
ax_b4.legend(fontsize=8, loc="upper right")


