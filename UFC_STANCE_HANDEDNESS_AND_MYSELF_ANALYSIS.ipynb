# C1 — 4-group box plot
ax_c1 = fig.add_subplot(gs[3, 0])
style_ax(ax_c1, "WIN RATE — 4 DETAILED GROUPS", ylabel="Win Rate (%)")
g_data  = [GROUPS[k]["win_rate"].values for k in GROUPS]
g_short = ["Orth\nRight","Orth\nLeft","South\nLeft","South\nRight ★"]
bp2 = ax_c1.boxplot(
    g_data, patch_artist=True, widths=0.52,
    medianprops=dict(color=UFC_WHITE, lw=2.5),
    whiskerprops=dict(color=UFC_SILVER, lw=1.2),
    capprops=dict(color=UFC_SILVER, lw=1.2),
    flierprops=dict(marker="o", ms=3, color=UFC_SILVER, alpha=0.3))
for patch, col in zip(bp2["boxes"], [UFC_GREY, UFC_GREY, UFC_GREY, UFC_GOLD]):
    patch.set(facecolor=col, alpha=0.75)
ax_c1.set_xticks([1,2,3,4])
ax_c1.set_xticklabels(g_short, color=UFC_WHITE, fontsize=8)
ax_c1.get_xticklabels()[3].set_color(UFC_GOLD)
red_line(ax_c1)

# C2 — My group vs others
ax_c2 = fig.add_subplot(gs[3, 1])
style_ax(ax_c2, "MY GROUP vs ALL OTHERS", ylabel="Win Rate (%)")
comp_m = [my_s["mean"], others_mean]
comp_s = [my_s["std"],  others["win_rate"].std()]
b2 = ax_c2.bar([0,1], comp_m, yerr=comp_s, capsize=10,
               color=[UFC_GOLD, UFC_GREY], alpha=0.85,
               edgecolor=UFC_WHITE, linewidth=0.7,
               error_kw=dict(ecolor=UFC_WHITE, lw=1.4, capthick=1.4), width=0.55)
ax_c2.set_xticks([0,1])
ax_c2.set_xticklabels(["Me (R-hand\nSouthpaw)","All Others"], color=UFC_WHITE, fontsize=9)
red_line(ax_c2); ax_c2.set_ylim(0, 100)
for bar, m in zip(b2, comp_m):
    ax_c2.text(bar.get_x()+bar.get_width()/2, bar.get_height()+3.5,
               f"{m:.1f}%", ha="center", color=UFC_WHITE, fontsize=10, fontweight="bold")
diff = my_s["mean"] - others_mean
ax_c2.text(0.5, 0.93, f"Difference: {diff:+.2f}%",
           transform=ax_c2.transAxes, ha="center",
           color=UFC_GOLD if diff>0 else UFC_RED, fontsize=9, fontweight="bold")
ax_c2.text(0.98, 0.06, f"p={p_me:.4f}  {'★' if p_me<.05 else 'n.s.'}",
           transform=ax_c2.transAxes, ha="right", color=UFC_GOLD, fontsize=8)

# C3 — My group histogram
ax_c3 = fig.add_subplot(gs[3, 2])
style_ax(ax_c3, "MY GROUP WIN RATE DISTRIBUTION",
         xlabel="Win Rate (%)", ylabel="# Fighters")
bins3 = np.linspace(0, 100, 14)
n_v, edges, patches_h = ax_c3.hist(
    MY_GROUP["win_rate"], bins=bins3,
    color=UFC_GOLD, alpha=0.8, edgecolor=UFC_BLACK, linewidth=0.8)
for patch, left in zip(patches_h, edges[:-1]):
    patch.set_facecolor(UFC_GOLD if left >= 50 else UFC_RED); patch.set_alpha(0.80)
ax_c3.axvline(MY_GROUP["win_rate"].mean(), color=UFC_WHITE, lw=2,
              label=f"Mean {MY_GROUP['win_rate'].mean():.1f}%")
ax_c3.axvline(50, color=UFC_RED, lw=1.5, ls="--", alpha=0.7, label="50%")
ax_c3.legend(fontsize=8)

# C4 — Stats card
ax_c4 = fig.add_subplot(gs[3, 3])
ax_c4.set_facecolor(UFC_PANEL); ax_c4.axis("off")
ax_c4.add_patch(FancyBboxPatch((0.04,0.03), 0.92, 0.94,
    boxstyle="round,pad=0.02", lw=2,
    edgecolor=UFC_GOLD, facecolor="#1A1200",
    transform=ax_c4.transAxes, zorder=0))

def card(ax, y, label, val, vc=UFC_WHITE):
    ax.text(0.12, y, label, transform=ax.transAxes,
            color=UFC_SILVER, fontsize=8, va="center")
    ax.text(0.88, y, val, transform=ax.transAxes,
            color=vc, fontsize=9, va="center", ha="right", fontweight="bold")

ax_c4.text(0.5, 0.93, "MY GROUP PROFILE",
           transform=ax_c4.transAxes, color=UFC_GOLD,
           fontsize=10, fontweight="bold", ha="center", va="center")
ax_c4.text(0.5, 0.86, "Right-handed Southpaw",
           transform=ax_c4.transAxes, color=UFC_WHITE,
           fontsize=9, ha="center", va="center")
ax_c4.plot([0.06, 0.94], [0.82, 0.82], color=UFC_GOLD, lw=0.8, alpha=0.5,
           transform=ax_c4.transAxes)
card(ax_c4, 0.75, "Fighters in dataset",   f"{my_s['n']}  ({my_s['pct']:.1f}%)")
card(ax_c4, 0.67, "Mean Win Rate",          f"{my_s['mean']:.2f}%", UFC_GOLD)
card(ax_c4, 0.59, "Median Win Rate",        f"{my_s['median']:.2f}%")
card(ax_c4, 0.51, "Std Deviation",          f"±{my_s['std']:.2f}%")
card(ax_c4, 0.43, "Range",                  f"{my_s['min']}% – {my_s['max']}%")
ax_c4.plot([0.06, 0.94], [0.38, 0.38], color=UFC_GREY, lw=0.5, alpha=0.4,
           transform=ax_c4.transAxes)

vs_or = my_s["mean"] - orth_right_s["mean"]
vs_sl = my_s["mean"] - south_left_s["mean"]
vs_ot = my_s["mean"] - others_mean
card(ax_c4, 0.31, "vs Orth. Right-hand",
     f"{vs_or:+.2f}%", UFC_GOLD if vs_or>0 else UFC_RED)
card(ax_c4, 0.23, "vs Trad. Southpaw",
     f"{vs_sl:+.2f}%", UFC_GOLD if vs_sl>0 else UFC_RED)
card(ax_c4, 0.15, "vs All Others",
     f"{vs_ot:+.2f}%", UFC_GOLD if vs_ot>0 else UFC_RED)
ax_c4.plot([0.06, 0.94], [0.10, 0.10], color=UFC_GOLD, lw=0.8, alpha=0.5,
           transform=ax_c4.transAxes)
verdict = "DATA SUPPORTS MY STANCE!" if my_s["mean"]>others_mean else "KEEP GRINDING!"
ax_c4.text(0.5, 0.05, verdict, transform=ax_c4.transAxes,
           color=UFC_GOLD, fontsize=8, fontweight="bold", ha="center", va="center")


